{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "tests/dist",
    "rootDir": "."
  },
  "include": [
    "src/physics/vec3.ts",
    "src/physics/orbital.ts",
    "src/physics/attitude.ts",
    "src/physics/atmosphere.ts",
    "src/physics/ephemeris.ts",
    "tests/physics/**/*.ts"
  ]
}
